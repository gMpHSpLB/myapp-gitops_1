# Self-documenting help: list targets with "##" comments
help: ## Show all available targets with short descriptions.
	# This target reads the Makefile and prints any line ending with ##.
	# Use this when you want to discover available commands quickly.
	# Expected output: a list of targets and one-line descriptions.
	@awk 'BEGIN {FS = ":.*##"; printf "\nUsage:\n  make <target>\n\nTargets:\n"} /^[a-zA-Z0-9_.-]+:.*##/ { printf "  %-28s %s\n", $$1, $$2 }' $(MAKEFILE_LIST)

# ---------- GLOBAL CONFIG --------------------------------------
# Load secrets from .secrets if present
# What this does:
# 	- If .secrets exists, include it so GHCR_USERNAME and GHCR_PAT become Make variables.
# 	- export the variable names parsed from the file so they are available to shell commands run by Make.
SECRETS_FILE ?= .secrets

ifneq ("$(wildcard $(SECRETS_FILE))","")
include $(SECRETS_FILE)
export $(shell sed -n 's/^\([A-Za-z_][A-Za-z0-9_]*\)=.*/\1/p' $(SECRETS_FILE))
endif

RED    := \033[1;31m
YELLOW := \033[1;33m
GREEN  :="\033[1;32m"
CYAN   := \033[1;36m
RESET  := \033[0m

ARGOCD_CLI_INSTALLER_URL 				?= https://github.com/argoproj/argo-cd/releases/latest/download/argocd-linux-amd64
ARGOCD_CLI_TOOL 						?= bin/argocd

# Set ARGOCD_SERVER to the service, not localhost
ARGOCD_PORT 							?= 8080
ARGOCD_SERVER_URL						?= localhost:$(ARGOCD_PORT)
ARGOCD_USERNAME 						?= admin
ARGOCD_ADMIN_PASSWORD					?= admin123
#Set to true in-case you want to delete the initial argocd server password
DELETE_INITIAL_ARGOCD_ADMIN_PASSWORD	?= false
# For local dev, we often disable TLS verification for the CLI.
# Set to false if you want to disable insecure login
DISABLE_INSECURE_PATCH 					?= true
ARGOCD_INSECURE 						?= true
ARGOCD_PF_LOG 							?= /tmp/argocd-port-forward.log
ARGOCD_PF_PID 							?= /tmp/argocd-port-forward.pid
# ---------- APP NAMESPACES PER ENV ------------------------
K8S_ARGOCD_NAMESPACE 					?= argocd
ARGOCD_MANIFEST_URL 					?= https://raw.githubusercontent.com/argoproj/argo-cd/stable/manifests/install.yaml

ARGOCD_CMD_PARAMS_CM           			?= argocd-cmd-params-cm
ARGOCD_MAIN_CM                 			?= argocd-cm
ARGOCD_SERVER_DEPLOYMENT       			?= argocd-server

ARGOCD_SERVER_INSECURE_KEY     			?= server.insecure
ARGOCD_SERVER_INSECURE_VALUE   			?= false

ARGOCD_RESOURCE_TRACKING_KEY   			?= application.resourceTrackingMethod
ARGOCD_RESOURCE_TRACKING_VALUE 			?= annotation

ARGOCD_TIMEOUT_RECONCILIATION_KEY        ?= timeout.reconciliation
ARGOCD_TIMEOUT_RECONCILIATION_VALUE      ?= 180s
ARGOCD_TIMEOUT_HARD_RECONCILIATION_KEY   ?= timeout.hard.reconciliation
ARGOCD_TIMEOUT_HARD_RECONCILIATION_VALUE ?= 0

GITOPS_SOURCE_PROJECT					 ?= Gitops-ArgoCD-1-Source
# -----------------------------------------------------------------
k8s-get-pods-in-argocd-namespace:
	@printf '$(YELLOW) %s $(RESET) \n' \
		'Get pods in namespace: $(K8S_ARGOCD_NAMESPACE)'
	kubectl get pods -n $(K8S_ARGOCD_NAMESPACE)

k8s-argocd-create-namespace:
	@printf '$(YELLOW) %s $(RESET) \n' \
		'Ensuring ArgoCD namespace exists: $(K8S_ARGOCD_NAMESPACE)'
	@kubectl create namespace $(K8S_ARGOCD_NAMESPACE) --dry-run=client -o yaml | kubectl apply -f -

k8s-argocd-install: k8s-argocd-create-namespace
	@printf '$(YELLOW)%s$(RESET)\n' \
		'Create Namespace: $(K8S_ARGOCD_NAMESPACE)' \
		'Installing ArgoCD from $(ARGOCD_MANIFEST_URL)' \
		'Stable release manifest (not core install; core has no UI)'
	@kubectl apply -n $(K8S_ARGOCD_NAMESPACE) \
		--server-side --force-conflicts \
		-f $(ARGOCD_MANIFEST_URL)

	@echo "Watch components come up — all must be Running"
	# Expected components:
	# argocd-application-controller-0          (StatefulSet)
	# argocd-applicationset-controller-xxx     (Deployment)
	# argocd-dex-server-xxx                    (Deployment)
	# argocd-notifications-controller-xxx      (Deployment)
	# argocd-redis-xxx                         (Deployment)
	# argocd-repo-server-xxx                   (Deployment)
	# argocd-server-xxx                        (Deployment)

	$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-get-pods-in-argocd-namespace

	@printf '$(GREEN) %s $(RESET) \n' \
		'7 components Expected:' \
		'----------------------' \
		'Component					What it does				Required' \
		'application-controller	The sync engine — the core of ArgoCD			Yes' \
		'repo-server			Renders Helm/Kustomize manifests in isolation		Yes' \
		'server			API + UI. Handles logins, sync requests			Yes' \
		'dex-server			SSO/OIDC integration					No (but installed by default)' \
		'redis			Caches rendered manifests, reduces repo-server load	Yes' \
		'applicationset-controller	Manages ApplicationSet resources			Yes' \
		'notifications-controller	Sends Slack/email alerts on sync events			No' \

k8s-argocd-verify:
	@printf '$(YELLOW) %s $(RESET) \n' \
		'Waiting for ArgoCD pods to become Ready'
	@kubectl wait --for=condition=Ready pods \
		--all \
		-n $(K8S_ARGOCD_NAMESPACE) \
		--timeout=300s || echo "Warning: ArgoCD pods not all Ready within timeout; will continue and check status."
	@kubectl get pods -n $(K8S_ARGOCD_NAMESPACE)

install_argocd_on_minikube:
	@printf '$(YELLOW) %s $(RESET) \n' \
		'Check ArgoCD Server is already installed?'
	@if kubectl get deploy argocd-server -n $(K8S_ARGOCD_NAMESPACE) >/dev/null 2>&1; then \
		printf '$(GREEN) %s $(RESET) \n' \
			'ArgoCD is already installed and running. Skipping install, but verify status'; \
		$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-verify; \
	else \
		$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-install; \
		$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-verify; \
	fi

k8s-argocd-check-argocd-server-accessible:
	@printf '$(YELLOW) %s $(RESET)\n' \
		'Checking whether Argo CD server is reachable on local access port'
	@if lsof -i :$(ARGOCD_PORT) >/dev/null 2>&1; then \
		if curl -sk https://127.0.0.1:$(ARGOCD_PORT)/healthz >/dev/null 2>&1; then \
			printf '$(GREEN) %s $(RESET)\n' \
				"Argo CD server is reachable on localhost:$(ARGOCD_PORT)"; \
		else \
			printf '$(YELLOW) %s $(RESET)\n' \
				"Port $(ARGOCD_PORT) is open, but Argo CD is not responding. Restarting port-forward."; \
			$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-expose-argocd-server-to-localaccess; \
		fi; \
	else \
		printf '$(YELLOW) %s $(RESET)\n' \
			"Argo CD server is not reachable on localhost:$(ARGOCD_PORT)"; \
		$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-expose-argocd-server-to-localaccess; \
	fi

k8s-argocd-expose-argocd-server-to-localaccess: ## Expose argocd server for local access
	@printf '$(YELLOW) %s $(RESET)\n' \
		'ArgoCD server is ClusterIP by default — exposing it for local access'
	@if lsof -i :$(ARGOCD_PORT) >/dev/null 2>&1; then \
		printf '$(GREEN) %s $(RESET)\n' \
			"Port $(ARGOCD_PORT) is already in use. Reusing existing port-forward or stop it first."; \
	else \
		printf '$(YELLOW) %s $(RESET)\n' 'Starting port-forward in the background'; \
		kubectl port-forward svc/argocd-server -n $(K8S_ARGOCD_NAMESPACE) $(ARGOCD_PORT):443 > $(ARGOCD_PF_LOG) 2>&1 & \
		echo $$! > $(ARGOCD_PF_PID); \
		sleep 3; \
		if curl -sk https://127.0.0.1:$(ARGOCD_PORT)/healthz >/dev/null 2>&1; then \
			printf '$(GREEN) %s $(RESET)\n' \
				"Argo CD is now reachable on localhost:$(ARGOCD_PORT)"; \
		else \
			printf '$(RED) %s $(RESET)\n' \
				"Port-forward started but Argo CD is still not reachable"; \
			exit 1; \
		fi; \
	fi

k8s-argocd-get-initial-admin-password:
	@printf '$(YELLOW) %s $(RESET)\n' \
		'Get the initial admin password' \
		'It is stored in a Secret and auto-generated during install'; \

	@INITIAL_PASS="$$(kubectl get secret argocd-initial-admin-secret \
		-n $(K8S_ARGOCD_NAMESPACE) \
		-o jsonpath='{.data.password}' | base64 --decode)"; \
	if [ -z "$$INITIAL_PASS" ]; then \
		printf '$(GREEN)%s$(RESET)\n' "Initial admin password secret not found or empty; assuming password was already changed."; \
		exit 0; \
	fi; \
	printf '$(GREEN) %s %s $(RESET)\n' 'Admin password:' "$$ARGOCD_PASSWORD"

k8s-argocd-install-argocd-cli-tool:
	@if [ -x "$(ARGOCD_CLI_TOOL)" ]; then  \
		printf '$(GREEN) %s $(RESET)\n' "$(ARGOCD_CLI_TOOL) already installed; skipping download."; \
		$(ARGOCD_CLI_TOOL) version --client; \
	else \
		printf '$(YELLOW) %s $(RESET)\n' "Installing the ArgoCD CLI tool"; \
		mkdir -p ./bin; \
		curl -sSL -o $(ARGOCD_CLI_TOOL) "$(ARGOCD_CLI_INSTALLER_URL)"; \
		chmod +x $(ARGOCD_CLI_TOOL); \
		printf '$(YELLOW) %s $(RESET)\n' "Verify argocd CLI is installed, check version"; \
		$(ARGOCD_CLI_TOOL) version --client; \
	fi

k8s-argocd-login-argocd-server-via-cli: k8s-argocd-check-argocd-server-accessible
	@if [ -n "$(ARGOCD_ADMIN_PASSWORD)" ]; then \
		PASS="$(ARGOCD_ADMIN_PASSWORD)"; \
	else \
		PASS="$$(kubectl -n $(K8S_ARGOCD_NAMESPACE) get secret argocd-initial-admin-secret -o jsonpath='{.data.password}' | base64 -d; echo)"; \
	fi; \
	$(ARGOCD_CLI_TOOL) login $(ARGOCD_SERVER_URL) \
		--username $(ARGOCD_USERNAME) \
		--password "$$PASS" \
		--insecure

k8s-argocd-change-argocd-server-admin-password:
	@printf '$(YELLOW)%s$(RESET)\n' "Change the default password immediately"
	@printf '$(YELLOW)%s$(RESET)\n' "Using the default password beyond first login is a security risk"

	@INITIAL_PASS="$$(kubectl get secret argocd-initial-admin-secret \
		-n $(K8S_ARGOCD_NAMESPACE) \
		-o jsonpath='{.data.password}' | base64 --decode)"; \
	if [ -z "$$INITIAL_PASS" ]; then \
		printf '$(GREEN)%s$(RESET)\n' "Initial admin password secret not found or empty; assuming password was already changed."; \
		exit 0; \
	fi; \
	echo "Checking if initial admin password is still valid..."; \
	if $(ARGOCD_CLI_TOOL) login "$(ARGOCD_SERVER_URL)" \
		--username "$(ARGOCD_USERNAME)" \
		--password "$$INITIAL_PASS" \
		--insecure >/dev/null 2>&1; then \
		printf '$(GREEN)%s$(RESET)\n' "Initial password still valid. Updating password..."; \
		$(ARGOCD_CLI_TOOL) account update-password \
			--current-password "$$INITIAL_PASS" \
			--new-password "admin123"; \
		printf '$(GREEN)%s$(RESET)\n' "New password set: admin123"; \
		echo "Optionally delete argocd-initial-admin-secret to prevent reuse."; \
	else \
		printf '$(GREEN)%s $(RESET)\n' "Initial password no longer valid; skipping password change."; \
	fi

k8s-argocd-delete-initial-password-after-reset:
	@if [ "$(DELETE_INITIAL_ARGOCD_ADMIN_PASSWORD)" = "false" ]; then \
		printf '$(GREEN) %s $(RESET)\n' 'Skipping to delete initial argocd server admin password.'; \
		exit 0; \
	else \
		printf '$(YELLOW) %s $(RESET)\n' "The initial secret is now stale — delete it"; \
		kubectl delete secret argocd-initial-admin-secret -n $(K8S_ARGOCD_NAMESPACE) ;\
	fi

access-argocd-server-ui-and-do-initial-configuration:
	$(MAKE)	-f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-expose-argocd-server-to-localaccess
	$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-get-initial-admin-password
	$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-install-argocd-cli-tool
	$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-change-argocd-server-admin-password	
	$(MAKE)	-f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-login-argocd-server-via-cli
	$(MAKE)	-f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-delete-initial-password-after-reset


k8s-disable-insecure-mode-of-argocd-server-by-applying-patch: ## Patch ArgoCD server to disable insecure mode
	@if [ "$(DISABLE_INSECURE_PATCH)" = "true" ]; then \
		printf '$(GREEN)%s$(RESET)\n' 'Skipping insecure-mode patch.'; \
		exit 0; \
	else \
		printf '$(YELLOW)%s$(RESET)\n' "Patch ArgoCD server to disable insecure mode."; \
		printf '$(YELLOW)%s$(RESET)\n' \
			"In production you would have a proper TLS cert — here we configure it correctly" \
			"even if the cert is self-signed."; \
		kubectl patch configmap $(ARGOCD_CMD_PARAMS_CM) -n $(K8S_ARGOCD_NAMESPACE) \
			--type merge \
			-p '{"data":{"$(ARGOCD_SERVER_INSECURE_KEY)":"$(ARGOCD_SERVER_INSECURE_VALUE)"}}' ; \
	fi

# Why annotation is better
# Argo CD needs a reliable way to remember “this live object belongs to that Application.” 
# With label-based tracking, Argo CD adds an identifying label, but labels are part of 
# Kubernetes metadata that can be used by selectors, so a label collision can create 
# unexpected behavior in Services, Deployments, or other label-driven controllers. 
# With annotation-based tracking, Argo CD writes tracking data into annotations, which 
# Kubernetes ignores for selection logic, so it is less likely to interfere with your app’s 
# functional labels.

# A practical example: suppose your Service selects pods with app=api. If Argo CD also used 
# a label with the same key or if a label strategy collided with your app labels, you could 
# accidentally change which pods the Service routes to. An annotation does not affect that 
# selector at all, so your routing stays driven only by your intended labels.

# What changes in multi-cluster setups
# Annotation-based tracking is also useful when you have multiple Argo CD instances or a larger 
# fleet because the tracking metadata is less likely to conflict with labels used by application 
# logic or platform policy. Argo CD can still determine ownership, but without forcing extra label 
# semantics into the resource-selection path. That is why many newer Argo CD setups prefer 
# annotation-based tracking as the default direction
k8s-set-resource-tracking-method-to-annotation-by-applying-patch: ## Set resource tracking method to annotation (more reliable than label)
	@printf '$(YELLOW)%s$(RESET)\n' "Set resource tracking method to annotation (more reliable than label)."
	@printf '$(YELLOW)%s$(RESET)\n' "This is how ArgoCD marks resources it manages."
	@printf '$(YELLOW)%s$(RESET)\n' \
		'application.resourceTrackingMethod: annotation' \
		'tells Argo CD to identify the live resources it owns' \
		'using annotations instead of relying only on labels'

	kubectl patch configmap $(ARGOCD_MAIN_CM) -n $(K8S_ARGOCD_NAMESPACE) \
		--type merge \
		-p '{"data":{"$(ARGOCD_RESOURCE_TRACKING_KEY)":"$(ARGOCD_RESOURCE_TRACKING_VALUE)"}}'

k8s-configure-resource-health-checks-timeout-by-applying-patch: ## Configure resource health checks timeout
	@printf '$(YELLOW)%s$(RESET)\n' "Configure resource health checks timeout."
	kubectl patch configmap $(ARGOCD_MAIN_CM) -n $(K8S_ARGOCD_NAMESPACE) \
		--type merge \
		-p '{"data":{"$(ARGOCD_TIMEOUT_RECONCILIATION_KEY)":"$(ARGOCD_TIMEOUT_RECONCILIATION_VALUE)","$(ARGOCD_TIMEOUT_HARD_RECONCILIATION_KEY)":"$(ARGOCD_TIMEOUT_HARD_RECONCILIATION_VALUE)"}}'

k8s-restart-argocd-server-to-pick-up-config-changes-by-applying-patch: ## Restart ArgoCD server to pick up config changes
	@printf '$(YELLOW)%s$(RESET)\n' "Restart ArgoCD server to pick up config changes."
	@printf '$(YELLOW)%s$(RESET)\n' \
		'Practical flow ' \
		'If you patch Argo CD ConfigMaps and then restart the server, the sequence is:' \
		'	- You change Argo CD config.' \
		'	- You restart the Deployment so the running pod picks up the new config.' \
		'	- Kubernetes replaces the old pod with a new one in a rolling way.' \
		'	- rollout status blocks until the rollout is healthy.'

	kubectl rollout restart deployment/$(ARGOCD_SERVER_DEPLOYMENT) -n $(K8S_ARGOCD_NAMESPACE)
	kubectl rollout status deployment/$(ARGOCD_SERVER_DEPLOYMENT) -n $(K8S_ARGOCD_NAMESPACE)

make-argocd-installation-production-ready-by-hardening-installation: ## Harden the ArgoCD Installation
	@printf '$(YELLOW)%s$(RESET)\n' "Harden the ArgoCD installation"
	@printf '$(YELLOW)%s$(RESET)\n' \
		"The default ArgoCD install is not production-ready." \
		"These changes matter even in a learning environment because you should learn the right habits."

	@printf '$(CYAN) %s $(RESET) \n' "Press ENTER to disable-insecure-mode-of-argocd-server-by-applying-patch..."; \
	read -r _
	$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-disable-insecure-mode-of-argocd-server-by-applying-patch

	@printf '$(CYAN) %s $(RESET) \n' "Press ENTER to set-resource-tracking-method-to-annotation-by-applying-patch..."; \
	read -r _
	$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-set-resource-tracking-method-to-annotation-by-applying-patch

	@printf '$(CYAN) %s $(RESET) \n' "Press ENTER to configure-resource-health-checks-timeout-by-applying-patch..."; \
	read -r _
	$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-configure-resource-health-checks-timeout-by-applying-patch

	@printf '$(CYAN) %s $(RESET) \n' "Press ENTER to restart-argocd-server-to-pick-up-config-changes-by-applying-patch..."; \
	read -r _	
	$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-restart-argocd-server-to-pick-up-config-changes-by-applying-patch
	@printf '$(CYAN) %s $(RESET) \n' "Again Expose ArgoCD Server to localaccess..."; \
	$(MAKE)	-f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-expose-argocd-server-to-localaccess

