.PHONY: ghcr-check-secrets
ghcr-check-secrets: 
	@if [ -z "$(GHCR_USERNAME)" ] || [ -z "$(GHCR_PAT)" ]; then \
	  echo "GHCR_USERNAME and GHCR_PAT must be set in .secrets"; \
	  exit 1; \
	fi


.PHONY: k8s-apply-argocd-oci-helm-lab-repo-secret
k8s-apply-argocd-oci-helm-lab-repo-secret: ## Apply ArgoCD Helm OCI repo Secret
	@printf '$(YELLOW) %s $(RESET)\n' 'Apply ArgoCD Helm OCI repo Secret (GHCR credentials)'
	kubectl apply -f argocd-oci-helm-lab-repo-secret.yaml
	@printf '$(GREEN) %s $(RESET)\n' 'Secret my-oci-helm-lab applied to argocd namespace'
	
# Use the actual GitHub repository:
register-public-helm-oci-repo-as-source-for-helm-chart-with-argocd: ghcr-check-secrets k8s-argocd-login-argocd-server-via-cli ## Register the public Helm OCI repo with ArgoCD
	@if [ -z "$(GHCR_USERNAME)" ] || [ -z "$(GHCR_PAT)" ]; then \
		printf '$(RED) %s $(RESET)\n' 'GHCR_USERNAME and GHCR_PAT must be set in the environment'; \
		exit 1; \
	else \
		printf '$(YELLOW) %s $(RESET)\n' 'Register the public Helm OCI repo as a source with ArgoCD'; \
		$(ARGOCD_CLI_TOOL) repo add ghcr.io/gmphsplb/helm-lab \
			--type helm \
			--name my-oci-helm-lab \
			--enable-oci \
			--username "$(GHCR_USERNAME)" \
			--password "$(GHCR_PAT)" \
			--upsert; \
	fi

	@printf '$(YELLOW) %s $(RESET)\n' 'Verify the connection'
	@$(ARGOCD_CLI_TOOL) repo list