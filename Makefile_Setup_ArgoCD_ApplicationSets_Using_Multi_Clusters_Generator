# ---------------------------------------------------------------------------------------------------------
#							Multi Clusters - Multiple environment (dev/staging/prod)
#	For a true multi-cluster per environment setup, you want three separate ArgoCD cluster entries 
#	(and secrets) with fixed environment labels:
# 		- dev-cluster → environment=dev
# 		- staging-cluster → environment=staging
# 		- prod-cluster → environment=prod
#
# 	Your existing myapp-clusters ApplicationSet will then generate one Application per cluster 
#	(myapp-dev-cluster, myapp-staging-cluster, myapp-prod-cluster) automatically.
#
#	How to set that up and wire it into Make.
# 1. Register three clusters with ArgoCD
# 	You can add clusters via CLI using argocd cluster add and your kubeconfigs. Assuming you have three kubeconfig contexts:
# 		- k8s-dev
# 		- k8s-staging
# 		- k8s-prod
# 	register them
#  Ex: # Dev cluster
#		argocd cluster add k8s-dev --name dev-cluster
# 	You should see dev-cluster, staging-cluster, prod-cluster.
#
# 2. Label each cluster secret with a fixed environment
#   Now set environment labels (and ensure secret-type=cluster) on each secret
#  Ex: # Dev cluster secret
#		kubectl label secret dev-cluster \
#			  -n argocd argocd.argoproj.io/secret-type=cluster environment=dev --overwrite
#
# 3. What Applications the myapp-clusters ApplicationSet will generate
#	With:
# 		- Cluster secrets: dev-cluster, staging-cluster, prod-cluster.
#		- Labels: environment=dev/staging/prod.
#
#
# 	This will generate:
# 	1. For dev-cluster:
# 			Name: myapp-dev-cluster.
# 			Dest: server=<dev cluster API>, namespace=myapp-dev.
# 			Values: $values/envs/dev/values.yaml (your dev values).
# 	2. For staging-cluster:
# 			Name: myapp-staging-cluster.
# 			Dest: server=<staging cluster API>, namespace=myapp-staging.
# 			Values: $values/envs/staging/values.yaml (once you add staging values).
# 	3. For prod-cluster:
# 			Name: myapp-prod-cluster.
# 			Dest: server=<prod cluster API>, namespace=myapp-prod.
# 			Values: $values/envs/prod/values.yaml.
# 	This is the “true multi-cluster per environment” pattern: each env has its own physical/remote cluster.
# ---------------------------------------------------------------------------------------------------------

# just ensure kubecontext is kind-dev before running any target
.PHONY: kind-use-dev-context
kind-use-dev-context: ## Switch kubectl context to kind-dev
	@kubectl config use-context kind-dev

.PHONY: kind-use-staging-context
kind-use-staging-context: ## Switch kubectl context to kind-kind-staging
	@kubectl config use-context kind-staging

.PHONY: kind-use-prod-context
kind-use-prod-context: ## Switch kubectl context to kind-kind-prod
	@kubectl config use-context kind-prod

# for Argo CD bootstrap on the dev cluster, you can wrap your existing install logic
.PHONY: install-argocd-on-dev
install-argocd-on-dev: kind-use-dev-context ## Install Argo CD on dev (hub) cluster
	@echo "Installing Argo CD on kind dev cluster..."
	@$(MAKE) -f Makefile_Setup_ArgoCD_ApplicationSets_Using_Multi_Clusters_Generator install-argocd-on-kind-dev

# Note: --validate=false tells kubectl not to fetch the OpenAPI schema from the 
#         API server before applying, which is where your TLS check currently fails.
# This is acceptable in a local kind lab but you would not do this in production.
# If you want the “correct” TLS setup later, we’d switch from apiServerAddress: "0.0.0.0" 
# to using a specific host IP and adding that IP to the API server cert SANs, as shown in 
# external access guides.
argocd-create-namespace:
	@printf '$(YELLOW) %s $(RESET) \n' \
		'Ensuring ArgoCD namespace exists: $(ARGOCD_NAMESPACE)'
	@kubectl create namespace $(ARGOCD_NAMESPACE) --dry-run=client -o yaml | kubectl apply --validate=false -f -

.PHONY: kind-dev-check-argocd-installed
kind-dev-check-argocd-installed: kind-use-dev-context ## Ensure Argo CD is installed on kind-kind-dev
	@echo "Current kubectl context:"
	@kubectl config current-context
	@echo "Checking argocd namespace on kind dev..."
	@if ! kubectl get ns argocd >/dev/null 2>&1; then \
	  echo "ERROR: 'argocd' namespace not found on kind dev. Run install-argocd-on-dev first."; \
	  exit 1; \
	fi
	@echo "'argocd' namespace found. Listing Argo CD pods:"
	@kubectl -n argocd get pods

.PHONY: install-argocd-on-kind-dev
install-argocd-on-kind-dev: kind-use-dev-context argocd-create-namespace
	@printf '$(YELLOW) %s $(RESET) \n' \
		'See current context?' ; \
	kubectl config current-context; \
	printf '$(CYAN) %s $(RESET) \n' "Press ENTER to continue..."; \
	read -r _

	@printf '$(YELLOW) %s $(RESET) \n' \
		'Check ArgoCD Server is already installed?'
	@if kubectl get deploy argocd-server -n $(ARGOCD_NAMESPACE) >/dev/null 2>&1; then \
		printf '$(GREEN) %s $(RESET) \n' \
			'ArgoCD is already installed and running. Skipping install, but verify status'; \
		$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-verify; \
	else \
		$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-install; \
		$(MAKE) -f Makefile_Setup_ArgoCD_GitOps_Platform_Engineering k8s-argocd-verify; \
	fi

.PHONY: k8s-argocd-check-argocd-server-accessible
k8s-argocd-check-argocd-server-accessible: kind-use-dev-context
	@printf '$(YELLOW) %s $(RESET)\n' \
		'Checking whether Argo CD server is reachable on local access port'
	@if lsof -i :$(ARGOCD_PORT) >/dev/null 2>&1; then \
		if curl -sk https://127.0.0.1:$(ARGOCD_PORT)/healthz >/dev/null 2>&1; then \
			printf '$(GREEN) %s $(RESET)\n' \
				"Argo CD server is reachable on localhost:$(ARGOCD_PORT)"; \
		else \
			printf '$(YELLOW) %s $(RESET)\n' \
				"Port $(ARGOCD_PORT) is open, but Argo CD is not responding. Restarting port-forward."; \
			$(MAKE) -f Makefile_Setup_ArgoCD_ApplicationSets_Using_Multi_Clusters_Generator k8s-argocd-expose-argocd-server-to-localaccess; \
		fi; \
	else \
		printf '$(YELLOW) %s $(RESET)\n' \
			"Argo CD server is not reachable on localhost:$(ARGOCD_PORT)"; \
		$(MAKE) -f Makefile_Setup_ArgoCD_ApplicationSets_Using_Multi_Clusters_Generator k8s-argocd-expose-argocd-server-to-localaccess; \
	fi

k8s-argocd-expose-argocd-server-to-localaccess: kind-use-dev-context ## Expose argocd server for local access
	@printf '$(YELLOW) %s $(RESET)\n' \
		'ArgoCD server is ClusterIP by default — exposing it for local access'
	@if lsof -i :$(ARGOCD_PORT) >/dev/null 2>&1; then \
		printf '$(GREEN) %s $(RESET)\n' \
			"Port $(ARGOCD_PORT) is already in use. Reusing existing port-forward or stop it first."; \
	else \
		printf '$(YELLOW) %s $(RESET)\n' 'Starting port-forward in the background'; \
		kubectl port-forward svc/argocd-server -n $(ARGOCD_NAMESPACE) $(ARGOCD_PORT):443 > $(ARGOCD_PF_LOG) 2>&1 & \
		echo $$! > $(ARGOCD_PF_PID); \
		for i in 1 2 3 4 5; do \
		  sleep 2; \
		  if curl -sk https://127.0.0.1:$(ARGOCD_PORT)/healthz >/dev/null 2>&1; then \
		    printf '$(GREEN) %s $(RESET)\n' "Argo CD is now reachable on localhost:$(ARGOCD_PORT)"; \
		    exit 0; \
		  fi; \
		done; \
		printf '$(RED) %s $(RESET)\n' \
			"Port-forward started but Argo CD is still not reachable"; \
		exit 1; \
	fi

k8s-argocd-get-initial-admin-password: kind-use-dev-context
	@printf '$(YELLOW) %s $(RESET)\n' \
		'Get the initial admin password' \
		'It is stored in a Secret and auto-generated during install'; \

	@INITIAL_PASS="$$(kubectl get secret argocd-initial-admin-secret \
		-n $(ARGOCD_NAMESPACE) \
		-o jsonpath='{.data.password}' | base64 --decode)"; \
	printf '$(GREEN) %s %s $(RESET)\n' 'Admin Initial password:' "$$INITIAL_PASS"; \
	if [ -z "$$INITIAL_PASS" ]; then \
		printf '$(GREEN)%s$(RESET)\n' "Initial admin password secret not found or empty; assuming password was already changed."; \
		exit 0; \
	else \
		printf '$(GREEN) %s %s $(RESET)\n' 'Admin password:' "$$INITIAL_PASS";\
	fi

.PHONY: argocd-login-argocd-server-via-cli
argocd-login-argocd-server-via-cli: kind-use-dev-context k8s-argocd-check-argocd-server-accessible ## Login to Argo CD via CLI using admin password or initial secret
	@echo "Logging in to Argo CD at $(ARGOCD_SERVER_URL) as $(ARGOCD_USERNAME)..."
	@PASS="$${ARGOCD_ADMIN_PASSWORD:-$$($(KUBECTL) -n $(ARGOCD_NAMESPACE) get secret argocd-initial-admin-secret -o jsonpath='{.data.password}' | base64 -d; echo)}"; \
	printf '$(GREEN) %s %s $(RESET)\n' 'Admin password:' "$$PASS";\
	$(ARGOCD_CLI_TOOL) login $(ARGOCD_SERVER_URL) \
		--username $(ARGOCD_USERNAME) \
		--password "$$PASS" \
		$(if $(ARGOCD_INSECURE),--insecure,)


.PHONY: k8s-apply-myapp-team-project
k8s-apply-myapp-team-project: ## Apply myapp-team AppProject
	$(KUBECTL) apply -f projects/myapp-team.yaml -n $(ARGOCD_NAMESPACE)

# Optional: where to store exported kubeconfigs
KIND_KUBECONFIG_DIR := tmp/kubeconfigs
# API server URLs for dev/staging/prod kind clusters
DEV_SERVER   := https://172.26.44.184:6443
STAGE_SERVER := https://172.26.44.184:6444
