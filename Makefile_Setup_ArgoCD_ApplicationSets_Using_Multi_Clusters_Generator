.PHONY: apply-staging-secret
apply-staging-secret: ## Apply Secret for STAGING environment
	kubectl apply \
		-f secrets/myapp-staging-secret.yaml


.PHONY: apply-prod-secret
apply-prod-secret: ## Apply Secret for PROD environment
	kubectl apply \
		-f secrets/myapp-prod-secret.yaml

# Reset: delete Applications, ApplicationSet, and namespaces for myapp envs
.PHONY: reset-myapp-envs-applications-and-namespaces
reset-myapp-envs-applications-and-namespaces: ## Delete myapp env Applications, ApplicationSet, and namespaces
	@echo "Deleting myapp-dev/staging/prod Applications (if they exist)..."
	-$(ARGOCD_CLI_TOOL) app delete myapp-dev --cascade --yes || true
	-$(ARGOCD_CLI_TOOL) app delete myapp-staging --cascade --yes || true
	-$(ARGOCD_CLI_TOOL) app delete myapp-prod --cascade --yes || true

	@echo "Deleting myapp-environments ApplicationSet (if it exists)..."
	-$(KUBECTL) --kubeconfig=$(KUBECONFIG) delete applicationset myapp-environments \
		-n $(ARGOCD_NAMESPACE) --ignore-not-found

	@echo "Deleting namespaces myapp-dev/staging/prod (if they exist)..."
	-$(KUBECTL) delete ns myapp-dev --ignore-not-found
	-$(KUBECTL) delete ns myapp-staging --ignore-not-found
	-$(KUBECTL) delete ns myapp-prod --ignore-not-found

# Verify reset (optional sanity check)
.PHONY: verify-reset-myapp-envs-applications-and-namespaces
verify-reset-myapp-envs-applications-and-namespaces:
	@echo "Verifying myapp env Applications and namespaces are gone..."
	-$(ARGOCD_CLI_TOOL) app get myapp-dev && echo "myapp-dev still exists" || echo "myapp-dev removed"
	-$(ARGOCD_CLI_TOOL) app get myapp-staging && echo "myapp-staging still exists" || echo "myapp-staging removed"
	-$(ARGOCD_CLI_TOOL) app get myapp-prod && echo "myapp-prod still exists" || echo "myapp-prod removed"
	-$(KUBECTL) get ns myapp-dev && echo "ns/myapp-dev still exists" || echo "ns/myapp-dev removed"
	-$(KUBECTL) get ns myapp-staging && echo "ns/myapp-staging still exists" || echo "ns/myapp-staging removed"
	-$(KUBECTL) get ns myapp-prod && echo "ns/myapp-prod still exists" || echo "ns/myapp-prod removed"

.PHONY: check-myapp-envs-applicationset-and-apps-exist
check-myapp-envs-applicationset-and-apps-exist:
	@echo "Checking existing ApplicationSet and Applications..."
	-$(KUBECTL) get applicationset myapp-environments -n $(ARGOCD_NAMESPACE) \
		&& echo "ApplicationSet myapp-environments exists" \
		|| echo "ApplicationSet myapp-environments not found"
	-$(ARGOCD_CLI_TOOL) app get myapp-dev && echo "myapp-dev exists" || echo "myapp-dev not found"
	-$(ARGOCD_CLI_TOOL) app get myapp-staging && echo "myapp-staging exists" || echo "myapp-staging not found"
	-$(ARGOCD_CLI_TOOL) app get myapp-prod && echo "myapp-prod exists" || echo "myapp-prod not found"

# Apply the ApplicationSet that generates myapp-dev/staging/prod
.PHONY: k8s-apply-myapp-multi-clusters-applicationset-to-cluster
k8s-apply-myapp-multi-clusters-applicationset-to-cluster:
	$(KUBECTL) apply \
		-n $(ARGOCD_NAMESPACE) \
		-f applicationsets/myapp-multi-clusters.yaml

# Watch all myapp-* Applications until they reach Synced & Healthy, with timeout
.PHONY: argocd-watch-status-of-myapp-envs-applications
argocd-watch-status-of-myapp-envs-applications:
	@echo "Watching status of myapp-dev/staging/prod Applications (timeout 300s)..."
	@timeout 300s $(ARGOCD_CLI_TOOL) app wait myapp-dev myapp-staging myapp-prod \
		--health --sync || \
		( echo "Timed out waiting for myapp env Applications to become Healthy+Synced"; exit 1 )
	

# Get detailed status for each env Application
.PHONY: argocd-get-detailed-status-of-myapp-envs-applications
argocd-get-detailed-status-of-myapp-envs-applications:
	$(ARGOCD_CLI_TOOL) app get myapp-dev || true
	$(ARGOCD_CLI_TOOL) app get myapp-staging || true
	$(ARGOCD_CLI_TOOL) app get myapp-prod || true

# See resources ArgoCD created for each env Application
.PHONY: argocd-see-resources-of-myapp-envs-applications
argocd-see-resources-of-myapp-envs-applications:
	$(ARGOCD_CLI_TOOL) app resources myapp-dev || true
	$(ARGOCD_CLI_TOOL) app resources myapp-staging || true
	$(ARGOCD_CLI_TOOL) app resources myapp-prod || true

# See diff between desired and actual for each env Application
.PHONY: argocd-see-diff-of-myapp-envs-applications
argocd-see-diff-of-myapp-envs-applications:
	$(ARGOCD_CLI_TOOL) app diff myapp-dev || true
	$(ARGOCD_CLI_TOOL) app diff myapp-staging || true
	$(ARGOCD_CLI_TOOL) app diff myapp-prod || true

.PHONY: argocd-sync-and-wait-myapp-dev
argocd-sync-and-wait-myapp-dev: ## Sync myapp-dev and wait for Healthy+Synced
	@echo "Syncing myapp-dev..."
	@$(ARGOCD_CLI_TOOL) app sync myapp-dev || \
		( echo "Failed to start sync for myapp-dev"; exit 1 )

	@echo "Waiting for myapp-dev to be Synced and Healthy (timeout 300s)..."
	@$(ARGOCD_CLI_TOOL) app wait myapp-dev --sync --health --timeout 300 || \
		( echo "myapp-dev did not reach Synced+Healthy within timeout"; \
		  $(ARGOCD_CLI_TOOL) app get myapp-dev; \
		  exit 1 )

.PHONY: argocd-sync-and-wait-myapp-staging
argocd-sync-and-wait-myapp-staging: ## Sync myapp-staging and wait for Healthy+Synced
	@echo "Syncing myapp-staging..."
	@$(ARGOCD_CLI_TOOL) app sync myapp-staging || \
