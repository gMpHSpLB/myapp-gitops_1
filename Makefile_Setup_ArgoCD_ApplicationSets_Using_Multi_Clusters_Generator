.PHONY: prepare-kind-kubeconfig-dir
prepare-kind-kubeconfig-dir:
	mkdir -p $(KIND_KUBECONFIG_DIR)

.PHONY: export-kind-kubeconfigs
export-kind-kubeconfigs: prepare-kind-kubeconfig-dir
	@for ctx in kind-dev kind-staging kind-prod; do \
		echo "Exporting kubeconfig for $$ctx..."; \
		kubectl config use-context $$ctx >/dev/null; \
		kubectl config view --raw --minify --context $$ctx > $(KIND_KUBECONFIG_DIR)/$$ctx-kubeconfig.yaml; \
	done

#1. To register three clusters (idempotent)
# Helper: register one cluster only if it's not already present
#	kind create cluster --name dev creates a kubeconfig context named kind-kind-dev.
#		argocd cluster add kind-dev --name dev-cluster tells Argo CD:
#			Use the credentials from the dev context in ~/.kube/config.
# 	Create a cluster secret named dev-cluster in argocd namespace.
#
# Helper: register a cluster if not present
define REGISTER_CLUSTER_IF_NEEDED
@if ! $(ARGOCD_CLI_TOOL) cluster list | awk 'NR>1 {print $$2}' | grep -qx $(2); then \
	echo "Registering cluster '$(2)' from context '$(1)'..."; \
	$(ARGOCD_CLI_TOOL) cluster add $(1) --name $(2); \
else \
	echo "Cluster '$(2)' already registered in Argo CD, skipping."; \
fi
endef

# Helper: label the Argo CD cluster secret by matching decoded .data.server value
define LABEL_CLUSTER_BY_SERVER
	@SECRET_NAME=$$($(KUBECTL) -n $(ARGOCD_NAMESPACE) get secrets \
	  -l argocd.argoproj.io/secret-type=cluster \
	  -o jsonpath='{.items[*].metadata.name}'); \
	for s in $$SECRET_NAME; do \
	  SERVER=$$($(KUBECTL) -n $(ARGOCD_NAMESPACE) get secret $$s -o jsonpath='{.data.server}' | base64 --decode); \
	  if [ "$$SERVER" = "$(1)" ]; then \
	    echo "Labeling $$s as environment=$(2) (server $$SERVER)"; \
	    $(KUBECTL) -n $(ARGOCD_NAMESPACE) label secret $$s environment=$(2) --overwrite; \
	    exit 0; \
	  fi; \
	done; \
	echo "ERROR: no Argo CD cluster secret found for server $(1)"; \
	exit 1
endef

.PHONY: register-dev-staging-prod-clusters-in-argocd
register-dev-staging-prod-clusters-in-argocd: argocd-login-argocd-server-via-cli
	$(call REGISTER_CLUSTER_IF_NEEDED,kind-dev,dev-cluster)
	$(call REGISTER_CLUSTER_IF_NEEDED,kind-staging,staging-cluster)
	$(call REGISTER_CLUSTER_IF_NEEDED,kind-prod,prod-cluster)

#2. Label each cluster once (fixed env mapping)
.PHONY: label-dev-cluster-for-myapp
label-dev-cluster-for-myapp: ## Label dev cluster secret as environment=dev for myapp cluster generator
	$(call LABEL_CLUSTER_BY_SERVER,$(DEV_SERVER),dev)

.PHONY: label-staging-cluster-for-myapp
label-staging-cluster-for-myapp: ## Label staging cluster secret as environment=staging for myapp cluster generator
	$(call LABEL_CLUSTER_BY_SERVER,$(STAGE_SERVER),staging)

.PHONY: label-prod-cluster-for-myapp
label-prod-cluster-for-myapp: ## Label prod cluster secret as environment=prod for myapp cluster generator
	$(call LABEL_CLUSTER_BY_SERVER,$(PROD_SERVER),prod)

#3.  Apply myapp-clusters ApplicationSet to argocd namespace in multi clusters 
.PHONY: k8s-apply-myapp-multi-clusters-applicationset-to-cluster
k8s-apply-myapp-multi-clusters-applicationset-to-cluster: ## Apply myapp-clusters ApplicationSet to argocd namespace in multi clusters 
	kubectl apply -f applicationsets/myapp-multi-clusters.yaml -n $(ARGOCD_NAMESPACE)

