# Use Bash for shell commands in recipes.
# This gives us better shell features than plain sh.
SHELL := /bin/bash

# Default target
.DEFAULT_GOAL := help

.PHONY: help #- Show all available targets with short descriptions.


# Self-documenting help: list targets with "##" comments
help: ## Show all available targets with short descriptions.
	# This target reads the Makefile and prints any line ending with ##.
	# Use this when you want to discover available commands quickly.
	# Expected output: a list of targets and one-line descriptions.
	@awk 'BEGIN {FS = ":.*##"; printf "\nUsage:\n  make <target>\n\nTargets:\n"} /^[a-zA-Z0-9_.-]+:.*##/ { printf "  %-28s %s\n", $$1, $$2 }' $(MAKEFILE_LIST)

# ---------- GLOBAL CONFIG --------------------------------------
KUBECONFIG 								?= ~/.kube/config
KUBECTL    								?= kubectl
ARGOCD_CLI_TOOL 						?= bin/argocd


# Set ARGOCD_SERVER to the service, not localhost
ARGOCD_PORT 							?= 8080
ARGOCD_SERVER_URL						?= localhost:$(ARGOCD_PORT)
ARGOCD_USERNAME 						?= admin
ARGOCD_ADMIN_PASSWORD					?= admin123
#Set to true in-case you want to delete the initial argocd server password
DELETE_INITIAL_ARGOCD_ADMIN_PASSWORD	?= false
# For local dev, we often disable TLS verification for the CLI.
# Set to false if you want to disable insecure login
DISABLE_INSECURE_PATCH 					?= true
ARGOCD_INSECURE 						?= true
ARGOCD_PF_LOG 							?= /tmp/argocd-port-forward.log
ARGOCD_PF_PID 							?= /tmp/argocd-port-forward.pid

ARGOCD_NAMESPACE 						?= argocd
ARGOCD_DEV_APP_NAME             		?= myapp-dev
ARGOCD_STAGING_APP_NAME        		 	?= myapp-staging
ARGOCD_PROD_APP_NAME            		?= myapp-prod
# --------------- ArgoCD Application ------------------------------
K8S_NAMESPACE_DEV 						?= myapp-dev
K8S_NAMESPACE_STAGING					?= myapp-staging
K8S_NAMESPACE_PROD						?= myapp-prod


KUBECONFIG ?= ~/.kube/config
KUBECTL    ?= kubectl
ARGOCD     ?= argocd
ARGOCD_NS  ?= argocd

# Reset: delete Applications, ApplicationSet, and namespaces for myapp envs
.PHONY: reset-myapp-envs-applications-and-namespaces
reset-myapp-envs-applications-and-namespaces: ## Delete myapp env Applications, ApplicationSet, and namespaces
	@echo "Deleting myapp-dev/staging/prod Applications (if they exist)..."
	-$(ARGOCD) app delete myapp-dev --cascade --yes || true
	-$(ARGOCD) app delete myapp-staging --cascade --yes || true
	-$(ARGOCD) app delete myapp-prod --cascade --yes || true

	@echo "Deleting myapp-environments ApplicationSet (if it exists)..."
	-$(KUBECTL) --kubeconfig=$(KUBECONFIG) delete applicationset myapp-environments \
		-n $(ARGOCD_NS) --ignore-not-found

	@echo "Deleting namespaces myapp-dev/staging/prod (if they exist)..."
	-$(KUBECTL) --kubeconfig=$(KUBECONFIG) delete ns myapp-dev --ignore-not-found
	-$(KUBECTL) --kubeconfig=$(KUBECONFIG) delete ns myapp-staging --ignore-not-found
	-$(KUBECTL) --kubeconfig=$(KUBECONFIG) delete ns myapp-prod --ignore-not-found

# Verify reset (optional sanity check)
.PHONY: verify-reset-myapp-envs-applications-and-namespaces
verify-reset-myapp-envs-applications-and-namespaces:
	@echo "Verifying myapp env Applications and namespaces are gone..."
	-$(ARGOCD) app get myapp-dev && echo "myapp-dev still exists" || echo "myapp-dev removed"
	-$(ARGOCD) app get myapp-staging && echo "myapp-staging still exists" || echo "myapp-staging removed"
	-$(ARGOCD) app get myapp-prod && echo "myapp-prod still exists" || echo "myapp-prod removed"
	-$(KUBECTL) --kubeconfig=$(KUBECONFIG) get ns myapp-dev && echo "ns/myapp-dev still exists" || echo "ns/myapp-dev removed"
	-$(KUBECTL) --kubeconfig=$(KUBECONFIG) get ns myapp-staging && echo "ns/myapp-staging still exists" || echo "ns/myapp-staging removed"
	-$(KUBECTL) --kubeconfig=$(KUBECONFIG) get ns myapp-prod && echo "ns/myapp-prod still exists" || echo "ns/myapp-prod removed"

.PHONY: check-myapp-envs-applicationset-and-apps-exist
check-myapp-envs-applicationset-and-apps-exist:
	@echo "Checking existing ApplicationSet and Applications..."
	-$(KUBECTL) get applicationset myapp-environments -n $(ARGOCD_NS) \
		&& echo "ApplicationSet myapp-environments exists" \
		|| echo "ApplicationSet myapp-environments not found"
	-$(ARGOCD) app get myapp-dev && echo "myapp-dev exists" || echo "myapp-dev not found"
	-$(ARGOCD) app get myapp-staging && echo "myapp-staging exists" || echo "myapp-staging not found"
	-$(ARGOCD) app get myapp-prod && echo "myapp-prod exists" || echo "myapp-prod not found"

# Apply the ApplicationSet that generates myapp-dev/staging/prod
.PHONY: k8s-apply-myapp-envs-applicationset-to-cluster
k8s-apply-myapp-envs-applicationset-to-cluster:
	$(KUBECTL) apply \
		-n $(ARGOCD_NAMESPACE) \
		-f applicationsets/myapp-envs.yaml

# Watch all myapp-* Applications until they reach Synced & Healthy, with timeout
.PHONY: argocd-watch-status-of-myapp-envs-applications
argocd-watch-status-of-myapp-envs-applications:
	@echo "Watching status of myapp-dev/staging/prod Applications (timeout 300s)..."
	@timeout 300s $(ARGOCD_CLI_TOOL) app wait myapp-dev myapp-staging myapp-prod \
		--health --sync || \
		( echo "Timed out waiting for myapp env Applications to become Healthy+Synced"; exit 1 )
	

# Get detailed status for each env Application
.PHONY: argocd-get-detailed-status-of-myapp-envs-applications
argocd-get-detailed-status-of-myapp-envs-applications:
	$(ARGOCD_CLI_TOOL) app get myapp-dev || true
	$(ARGOCD_CLI_TOOL) app get myapp-staging || true
	$(ARGOCD_CLI_TOOL) app get myapp-prod || true

# See resources ArgoCD created for each env Application
.PHONY: argocd-see-resources-of-myapp-envs-applications
argocd-see-resources-of-myapp-envs-applications:
	$(ARGOCD_CLI_TOOL) app resources myapp-dev || true
	$(ARGOCD_CLI_TOOL) app resources myapp-staging || true
	$(ARGOCD_CLI_TOOL) app resources myapp-prod || true

# See diff between desired and actual for each env Application
.PHONY: argocd-see-diff-of-myapp-envs-applications
argocd-see-diff-of-myapp-envs-applications:
	$(ARGOCD_CLI_TOOL) app diff myapp-dev || true
	$(ARGOCD_CLI_TOOL) app diff myapp-staging || true
	$(ARGOCD_CLI_TOOL) app diff myapp-prod || true

.PHONY: argocd-sync-and-wait-myapp-dev
argocd-sync-and-wait-myapp-dev: ## Sync myapp-dev and wait for Healthy+Synced
	@echo "Syncing myapp-dev..."
	@$(ARGOCD_CLI_TOOL) app sync myapp-dev || \
		( echo "Failed to start sync for myapp-dev"; exit 1 )

	@echo "Waiting for myapp-dev to be Synced and Healthy (timeout 300s)..."
	@$(ARGOCD_CLI_TOOL) app wait myapp-dev --sync --health --timeout 300 || \
		( echo "myapp-dev did not reach Synced+Healthy within timeout"; \
		  $(ARGOCD_CLI_TOOL) app get myapp-dev; \
		  exit 1 )

.PHONY: argocd-sync-and-wait-myapp-staging
argocd-sync-and-wait-myapp-staging: ## Sync myapp-staging and wait for Healthy+Synced
	@echo "Syncing myapp-staging..."
	@$(ARGOCD_CLI_TOOL) app sync myapp-staging || \
		( echo "Failed to start sync for myapp-staging"; exit 1 )

	@echo "Waiting for myapp-staging to be Synced and Healthy (timeout 300s)..."
	@$(ARGOCD_CLI_TOOL) app wait myapp-staging --sync --health --timeout 300 || \
		( echo "myapp-staging did not reach Synced+Healthy within timeout"; \
		  $(ARGOCD_CLI_TOOL) app get myapp-staging; \
		  exit 1 )

.PHONY: argocd-sync-and-wait-myapp-prod
argocd-sync-and-wait-myapp-prod: ## Sync myapp-prod and wait for Healthy+Synced
	@echo "Syncing myapp-prod..."
	@$(ARGOCD_CLI_TOOL) app sync myapp-prod || \
		( echo "Failed to start sync for myapp-prod"; exit 1 )

	@echo "Waiting for myapp-prod to be Synced and Healthy (timeout 300s)..."
	@$(ARGOCD_CLI_TOOL) app wait myapp-prod --sync --health --timeout 300 || \
		( echo "myapp-prod did not reach Synced+Healthy within timeout"; \
		  $(ARGOCD_CLI_TOOL) app get myapp-prod; \
		  exit 1 )